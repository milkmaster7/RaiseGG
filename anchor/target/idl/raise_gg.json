{
  "version": "0.1.0",
  "name": "raise_gg",
  "instructions": [
    {
      "name": "createMatch",
      "accounts": [
        { "name": "playerA", "isMut": true, "isSigner": true },
        { "name": "playerAAta", "isMut": true, "isSigner": false },
        { "name": "matchState", "isMut": true, "isSigner": false },
        { "name": "vault", "isMut": true, "isSigner": false },
        { "name": "usdcMint", "isMut": false, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false },
        { "name": "associatedTokenProgram", "isMut": false, "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false },
        { "name": "rent", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "matchId", "type": { "array": ["u8", 16] } },
        { "name": "stakeAmount", "type": "u64" },
        { "name": "authority", "type": "publicKey" }
      ]
    },
    {
      "name": "joinMatch",
      "accounts": [
        { "name": "playerB", "isMut": true, "isSigner": true },
        { "name": "playerBAta", "isMut": true, "isSigner": false },
        { "name": "matchState", "isMut": true, "isSigner": false },
        { "name": "vault", "isMut": true, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "matchId", "type": { "array": ["u8", 16] } }
      ]
    },
    {
      "name": "resolveMatch",
      "accounts": [
        { "name": "authority", "isMut": true, "isSigner": true },
        { "name": "matchState", "isMut": true, "isSigner": false },
        { "name": "vault", "isMut": true, "isSigner": false },
        { "name": "winnerAta", "isMut": true, "isSigner": false },
        { "name": "treasuryAta", "isMut": true, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "matchId", "type": { "array": ["u8", 16] } },
        { "name": "winner", "type": "publicKey" }
      ]
    },
    {
      "name": "cancelMatch",
      "accounts": [
        { "name": "authority", "isMut": true, "isSigner": true },
        { "name": "matchState", "isMut": true, "isSigner": false },
        { "name": "vault", "isMut": true, "isSigner": false },
        { "name": "playerAAta", "isMut": true, "isSigner": false },
        { "name": "playerBAta", "isMut": true, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "matchId", "type": { "array": ["u8", 16] } }
      ]
    }
  ],
  "accounts": [
    {
      "name": "MatchState",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "matchId", "type": { "array": ["u8", 16] } },
          { "name": "playerA", "type": "publicKey" },
          { "name": "playerB", "type": "publicKey" },
          { "name": "authority", "type": "publicKey" },
          { "name": "usdcMint", "type": "publicKey" },
          { "name": "stake", "type": "u64" },
          { "name": "status", "type": { "defined": "MatchStatus" } },
          { "name": "bump", "type": "u8" },
          { "name": "vaultBump", "type": "u8" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "MatchStatus",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Open" },
          { "name": "Locked" },
          { "name": "Completed" },
          { "name": "Cancelled" }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "MatchCreated",
      "fields": [
        { "name": "matchId", "type": { "array": ["u8", 16] }, "index": false },
        { "name": "playerA", "type": "publicKey", "index": true },
        { "name": "stakeAmount", "type": "u64", "index": false }
      ]
    },
    {
      "name": "MatchJoined",
      "fields": [
        { "name": "matchId", "type": { "array": ["u8", 16] }, "index": false },
        { "name": "playerB", "type": "publicKey", "index": true }
      ]
    },
    {
      "name": "MatchResolved",
      "fields": [
        { "name": "matchId", "type": { "array": ["u8", 16] }, "index": false },
        { "name": "winner", "type": "publicKey", "index": true },
        { "name": "payout", "type": "u64", "index": false }
      ]
    }
  ],
  "errors": [
    { "code": 6000, "name": "ZeroStake", "msg": "Stake amount must be greater than zero" },
    { "code": 6001, "name": "MatchNotOpen", "msg": "Match is not open" },
    { "code": 6002, "name": "AlreadyJoined", "msg": "Match already has two players" },
    { "code": 6003, "name": "SamePlayer", "msg": "Cannot play against yourself" },
    { "code": 6004, "name": "Unauthorized", "msg": "Not the match authority" },
    { "code": 6005, "name": "MatchNotLocked", "msg": "Match is not locked" },
    { "code": 6006, "name": "InvalidWinner", "msg": "Winner must be one of the two players" }
  ],
  "metadata": {
    "address": "RGGeskrowAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
  }
}
